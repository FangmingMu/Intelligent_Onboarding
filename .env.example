# --- 大模型 (LLM) 配置 ---
OPENAI_API_BASE="https://your-api-url/v1"
OPENAI_API_KEY="your-sk-key"
LLM_MODEL="qwen3.5-27b"

# --- 向量模型 (Embedding) 配置 ---
EMBED_URL="https://your-api-url/v1/embeddings"
EMBED_MODEL="bge-m3"

# --- 重排模型 (Rerank) 配置 ---
RERANK_URL="https://your-api-url/reranker/v2/rerank"
RERANK_MODEL="bge-reranker-v2-m3"
