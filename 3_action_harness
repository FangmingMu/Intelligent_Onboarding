from typing import Literal, Optional
from pydantic import BaseModel, Field
from enum import Enum

# --- 数据模型定义 ---

class IssueType(str, Enum):
    PASSWORD_RESET = "password_reset"
    PERMISSION_REQUEST = "permission_request"
    ENV_SETUP = "env_setup"

class Priority(str, Enum):
    P0 = "P0"
    P1 = "P1"
    P2 = "P2"

class EmployeeInfo(BaseModel):
    emp_id: str = Field(..., description="员工工号，唯一标识")
    name: str = Field(..., description="员工姓名")
    department: str = Field(..., description="所属部门")
    title: str = Field(..., description="岗位职级，如：初级研发、高级专家等")
    status: str = Field(..., description="在职状态")

class TicketResponse(BaseModel):
    status: str = Field(..., description="处理状态")
    ticket_id: str = Field(..., description="生成的工单流水号")
    message: str = Field(..., description="回显给用户的提示消息")

# --- 模拟数据库数据 ---

MOCK_EMPLOYEE_DB = {
    "张三": {
